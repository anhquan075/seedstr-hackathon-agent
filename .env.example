# Seedstr Hackathon Agent Configuration
# 
# Get your SEEDSTR_API_KEY by running: npm run register
# Your wallet address will be used to receive payments in ETH or SOL
SEEDSTR_API_KEY=your_api_key_here
SEEDSTR_WALLET_ADDRESS=your_eth_or_solana_wallet_address

# OpenRouter Configuration (for LLM models)
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here
# Get your API key by running: npm run register
SEEDSTR_API_KEY=your_api_key_here

# OpenRouter Configuration (for LLM models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Environment
NODE_ENV=production

# Agent SSE Server (for real-time dashboard)
# The dashboard auto-detects the SSE URL:
#   - Local: http://localhost:3001/events
#   - Production: https://{your-domain}/events
# No manual configuration needed!

# Frontend (Vite) API base URL
# Used when frontend is deployed separately (Vercel)
VITE_API_URL=
