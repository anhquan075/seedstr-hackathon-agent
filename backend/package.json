{
  "name": "seedstr-agent-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/agent/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/agent/cli.js start",
    "dev": "npm run build && npm run start",
    "register": "npx tsx src/scripts/register.ts",
    "update-skills": "npx tsx src/scripts/update-skills.ts",
    "test": "jest",
    "synthetic": "node dist/agent/synthetic-test.js",
    "production-e2e": "npm run build && node dist/agent/production-e2e-test.js",
    "smoke-test:sse": "npm run build && npx tsx src/tests/sse-smoke-test.ts"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@types/pg": "^8.18.0",
    "ai": "^6.0.0",
    "archiver": "^7.0.1",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "mathjs": "^15.1.1",
    "node-fetch": "^3.3.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "pusher-js": "^8.4.0-rc2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^20",
    "drizzle-kit": "^0.31.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.7.2"
  }
}
